        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "typescript": "~5.9.3",
        "vite": "^8.0.1",
        "vite-plugin-dts": "^4.5.4"
    }
